Items: {
	VoidBlade: {
		DisplayName: ヴォイドブレード
		Tooltip: 素早く連続斬りを繰り出す
	}

	Weapons: {
		Rogue: {
			Revelation: {
				Tooltip:
					'''
					鎌を投げる
					ステルス状態の場合、斬撃と火炎弾を発射する
					'''
				DisplayName: 大鎌の黙示録
			}

			Silence: {
				DisplayName: 静寂
				Tooltip: フライングディスクを投げ出すと引っ張ることができる
			}

			ShadewindLance: {
				Tooltip:
					'''
					虚無を宿した槍を投げる
					ステルス攻撃はより高いダメージを与え、無限に貫通する
					'''
				DisplayName: 影穿槍
			}

			Aquashard: {
				DisplayName: 大洋の破片
				Tooltip:
					'''
					敵に命中すると小さな結晶へと砕ける脆いジャベリンを投げる
					ステルス攻撃は敵を貫通し、命中時にジャベリンを粉砕する
					'''
			}

			SpearOfRadiance: {
				Tooltip:
					'''
					聖なる槍を素早く投げる
					ステルス攻撃は画面全体に十字の軌跡を描く
					'''
				DisplayName: 閃光の槍
			}

			AbyssalPiercer: {
				DisplayName: 深淵を穿つ者
				Tooltip:
					'''
					水没したジャベリンを投擲し、追尾する水爆弾へと爆発させる
					ステルス攻撃ではジャベリンが深淵の裂け目を開き、触手を噴出させ
					さらにステルス攻撃は最大5体の敵を貫通する
					'''
			}

			AzureOfFirmament: {
				DisplayName: 大空の紺碧
				Tooltip:
					'''
					素早く槍を投げる
					ステルス攻撃は周囲に羽根の爆発を引き起こし、それが追尾する 
					'''
			}

			ArbitratorII: {
				DisplayName: 二人目の仲裁者
				Tooltip:
					'''
					爆発するジャベリンを投げる
					ステルス攻撃では、ジャベリンが命中した標的に突き刺さる
					短時間の遅延の後、爆発して周囲の標的にダメージを与える。
					'''
			}

			Voidseeker: {
				Tooltip: ステルス攻撃はカーソルの位置へ瞬間移動し、大ダメージを与える
				DisplayName: 虚無の探求者
			}

			TheBeginingAndTheEnd: {
				DisplayName: 始源と終焉
				Tooltip:
					'''
					左ボタンまたは右ボタンで「始源の刻」もしくは「終焉の刻」を発動
					「終焉の刻」は「深淵の凝視」を付与、「始源の刻」は「蝕の刻印」を付与
					デバフのスタック数に応じて「残響の魂」または「蝕の魂」を召喚し消滅
					残響の魂は一定時間ターゲットを連続攻撃
					蝕の魂は帰還時に回復し、攻撃速度・攻撃力・クリティカル率を一時上昇
					ステルス攻撃は同時に二連ホーミングナイフを投擲、命中時に大量の魂を解き放つ
					'''
			}

			AmethystFrisbee: {
				Tooltip:
					'''
					輝くディスクを投げる 命中時に反転して戻ってくる
帰還中に重力を逆転・無視
ステルス攻撃は命中時に衝撃波を発生させる
					'''
				DisplayName: アメジスト・フリスビー
			}

			ProphecyFlyingKnife: {
				Tooltip:
					'''
					複数のホーミングナイフを発射する。
					ステルス攻撃はナイフを投擲し、命中時に6つの軌道にルーンオーブを生成する。
					'''
				DisplayName: 預言の刃
			}

			TheDeadCut: {
				DisplayName: 死の断ち切り
				Tooltip: 攻撃後にステルス状態を一部回復する
			}

			LunarPlank: {
				DisplayName: 月の板
				Tooltip:
					'''
					月の板を投げて敵を攻撃する
					ステルス攻撃は発生させ、追尾する月矢を放つ
					'''
			}

			AzafureSurgeRod: {
				DisplayName: アザフレ製サージロッド
				Tooltip:
					'''
					命中時に標的に刺さる。
					遅延後、近くの標的に稲妻を放つ
					ステルス攻撃では複数のロッドを投擲し、空中を浮遊しながら近くの標的に自動追尾する
					'''
			}

			TlipocasScythe: {
				DisplayName: ティポリカの鎌
				Tooltip: ""
			}

			AzafureLightMachineGun: {
				DisplayName: アザフレ製軽量型機関銃
				Tooltip:
					'''
					レーザーを高速連射、命中時にステルスを回復
					ステルス攻撃は重力の影響を受ける手榴弾を発射する
					'''
			}

			AzafureAirReaper: {
				DisplayName: アザフレ製空気の死神
				Tooltip:
					'''
					鎌を投げつけ、命中させて標的に突き刺し、複数の傷を負わせる
					ステルス攻撃では、命中後に標的を追跡し、前後に行き来しながら斬り続ける鎌を投げる
					'''
			}
		}
	}

